  "messages": [
    {
      "id": "VeilstoneStore1F_Text_Welcome",
      "en_US": [
        "Welcome to the fabulous Veilstone\n",
        "Department Store."
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_EnsureCustomerSatisfaction",
      "en_US": [
        "This department store knows how to\n",
        "ensure customer satisfaction.\r",
        "They really look after you once you\n",
        "become a regular customer."
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_FormalAirOfLuxury",
      "en_US": [
        "I like the formal air of a luxury\n",
        "department store."
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_IMadeAnAccessory",
      "en_US": [
        "I made an Accessory modeled after\n",
        "the Pokémon of a Trainer I met.\r",
        "Would you like one?\r"
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_DifferentLookForContests",
      "en_US": [
        "It’s a {STRVAR_1 31, 0, 0}.\r",
        "It will give your Pokémon a\n",
        "different look for Contests."
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_DiscoverANewYou",
      "en_US": [
        "Discover a new you!\n",
        "Veilstone Department Store"
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_Directory",
      "en_US": [
        "B1F: Food & Produce\r",
        "1F: Trainers’ Zone\r",
        "2F: Battle Collection\r",
        "3F: TM Corner\r",
        "4F: Poké Dolls & Goods\r",
        "5F: Rooftop Plaza"
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_StylistDiscoverANewYou",
      "en_US": [
        "Welcome! Ready to discover a new you?\r",
        "I restyle Trainers’ outfits. A change of\n",
        "color does wonders for the spirit!"
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_StylistWhichOutfit",
      "en_US": [
        "Which look shall we try?"
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_StylistThatOneIs",
      "en_US": [
        "Oh, excellent taste!\r",
        "That outfit is $3000.\n",
        "Shall I wrap it up for you?"
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_StylistLooksWonderful",
      "en_US": [
        "There! It looks wonderful on you.\r",
        "Come back anytime you’d like to\n",
        "change again, that one’s yours now."
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_StylistChangedIntoIt",
      "en_US": [
        "You already own that one, so it’s on\n",
        "the house. There you go!"
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_StylistNotEnoughMoney",
      "en_US": [
        "Oh dear... you don’t have enough\n",
        "money for that one."
      ]
    },
    {
      "id": "VeilstoneStore1F_Text_StylistMaybeNextTime",
      "en_US": [
        "No trouble at all!\n",
        "Do come see me another time."
      ]
    },
